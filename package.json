{
    "name": "stonks",
    "version": "0.0.0",
    "main": "http://localhost:5173",
    "node-remote": "http://localhost:5173",
    "private": true,
    "type": "module",
    "scripts": {
        "postinstall": "base-volta-off-of-nwjs",
        "dev": "concurrently -k npm:dev:vite npm:dev:nwjs",
        "dev:vite": "vite",
        "dev:nwjs": "wait-on -c ./build/nw/wait-on.config.json http-get://localhost:5173 && nw .",
        "bld": "exit 1 && npm run bld:vite && npm run bld:nwjs",
        "bld:vite": "vite build --out-dir ./out/vite",
        "bld:nwjs": "nwbuild --cacheDir=./node_modules/nw --outDir=./out/nw --managedManifest=./build/nw/manifest.json ./package.json ./out/vite/*",
        "e2e:vite": "vitest run",
        "e2e:nightwatch": "nightwatch --headless",
        "pkg:vite": "gh-pages -b staging -d ./out/vite -u \"github-actions-bot <support+actions@github.com>\""
    },
    "devDependencies": {
        "@nightwatch/apitesting": "^3.1.4",
        "@nightwatch/react": "ayushmanchhabra/nightwatch-plugin-react#vite",
        "@nightwatch/testing-library": "^0.1.1",
        "@testing-library/jest-dom": "^6.4.8",
        "@testing-library/react": "^16.0.0",
        "@types/chrome": "^0.0.270",
        "@types/nightwatch": "^2.3.31",
        "@types/node": "^22.2.0",
        "@types/nw.js": "^0.90.0",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "base-volta-off-of-nwjs": "^1.0.5",
        "concurrently": "^8.2.2",
        "gh-pages": "^6.1.1",
        "jsdom": "^24.1.1",
        "nightwatch": "^3.7.0",
        "nw": "^0.90.0-1",
        "nw-builder": "^4.9.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.5.4",
        "vite": "^5.4.1",
        "vite-plugin-nightwatch": "^0.4.6",
        "vitest": "^2.0.5",
        "wait-on": "^7.2.0"
    },
    "volta": {
        "node": "22.2.0"
    }
}
