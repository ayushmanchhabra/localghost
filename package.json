{
    "name": "stonks",
    "version": "0.0.0",
    "main": "http://localhost:5173",
    "node-remote": "http://localhost:5173",
    "private": true,
    "scripts": {
        "postinstall": "base-volta-off-of-nwjs",
        "dev": "concurrently -k npm:dev:vite npm:dev:nwjs",
        "dev:vite": "vite",
        "dev:nwjs": "wait-on -c ./build/nw/wait-on.config.json http-get://localhost:5173 && nw .",
        "bld": "exit 1 && npm run bld:vite && npm run bld:nwjs",
        "bld:vite": "vite build --out-dir ./out/vite",
        "bld:nwjs": "nwbuild --cacheDir=./node_modules/nw --outDir=./out/nw --managedManifest=./build/nw/manifest.json ./package.json ./out/vite/*",
        "e2e:vite": "vitest run",
        "pkg:vite": "gh-pages -b staging -d ./out/vite -u \"github-actions-bot <support+actions@github.com>\""
    },
    "devDependencies": {
        "@emotion/react": "^11.13.0",
        "@emotion/styled": "^11.13.0",
        "@fontsource/roboto": "^5.0.14",
        "@mui/icons-material": "^6.0.0",
        "@mui/material": "^6.0.0",
        "@testing-library/jest-dom": "^6.4.8",
        "@testing-library/react": "^16.0.0",
        "@types/chrome": "^0.0.280",
        "@types/node": "^22.2.0",
        "@types/nw.js": "^0.92.0",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "base-volta-off-of-nwjs": "^1.0.5",
        "concurrently": "^8.2.2",
        "gh-pages": "^6.1.1",
        "jsdom": "^25.0.0",
        "nw": "^0.93.0",
        "nw-builder": "^4.8.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.5.4",
        "vite": "^5.4.0",
        "vitest": "^2.0.5",
        "wait-on": "^8.0.0"
    },
    "volta": {
        "node": "22.11.0"
    }
}
